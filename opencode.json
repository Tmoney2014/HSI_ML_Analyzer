{
  "$schema": "https://opencode.ai/config.json",
  "theme": "opencode",
  "agent": {
    "build": {
      "description": "팀장 에이전트 — 전체 작업 조율, 서브에이전트 위임, 최종 검토",
      "model": "github-copilot/claude-sonnet-4.6",
      "mode": "primary",
      "temperature": 0.2,
      "steps": 30,
      "permission": {
        "edit": "allow",
        "bash": {
          "python *": "allow",
          "pytest *": "allow",
          "git *": "allow",
          "powershell *": "allow",
          "& scripts\\*": "allow",
          "Get-Content *": "allow",
          "Select-String *": "allow",
          "*": "ask"
        },
        "task": "allow"
      }
    },
    "feature-dev": {
      "description": "기능 개발 에이전트 — Python/PyQt5 MVVM 기능 구현 전담",
      "model": "github-copilot/gpt-4o",
      "mode": "primary",
      "temperature": 0.2,
      "steps": 25,
      "permission": {
        "edit": "allow",
        "bash": {
          "python *": "allow",
          "pytest *": "allow",
          "python -m ruff *": "allow",
          "python -m mypy *": "allow",
          "& scripts\\gate.ps1": "allow",
          "Get-Content *": "allow",
          "git diff *": "allow",
          "git status": "allow",
          "*": "ask"
        },
        "task": "deny"
      }
    },
    "bugfixer": {
      "description": "버그 수정 에이전트 — 근본 원인 분석, 재현 테스트, 수정 전담",
      "model": "github-copilot/claude-sonnet-4.5",
      "mode": "primary",
      "temperature": 0.1,
      "steps": 20,
      "permission": {
        "edit": "allow",
        "bash": {
          "python *": "allow",
          "pytest *": "allow",
          "python -m ruff *": "allow",
          "python -m mypy *": "allow",
          "& scripts\\gate.ps1": "allow",
          "Get-Content *": "allow",
          "git diff *": "allow",
          "git log *": "allow",
          "git blame *": "allow",
          "git status": "allow",
          "*": "ask"
        },
        "task": "deny"
      }
    },
    "reviewer": {
      "description": "코드 리뷰 에이전트 — 읽기 전용. 파일 수정 절대 불가. 교차 벤더 시각으로 맹점 탐지",
      "model": "github-copilot/gemini-2.5-pro",
      "mode": "subagent",
      "temperature": 0.1,
      "steps": 15,
      "permission": {
        "edit": "deny",
        "bash": {
          "git diff *": "allow",
          "git log *": "allow",
          "git show *": "allow",
          "git blame *": "allow",
          "Get-Content *": "allow",
          "Select-String *": "allow",
          "python -m ruff check *": "allow",
          "pytest * --collect-only": "allow",
          "*": "deny"
        },
        "task": "deny"
      }
    },
    "docs-writer": {
      "description": "문서 작성 에이전트 — Markdown 파일 전담. Python 소스 및 설정 파일 수정 불가",
      "model": "github-copilot/claude-haiku-4.5",
      "mode": "subagent",
      "temperature": 0.3,
      "steps": 15,
      "permission": {
        "edit": {
          "**/*.md": "allow",
          "**/*.rst": "allow",
          "**/*.txt": "allow",
          "**/*.py": "deny",
          "**/*.json": "deny",
          "**/*.ps1": "deny",
          "*": "deny"
        },
        "bash": {
          "ls *": "allow",
          "dir *": "allow",
          "Get-ChildItem *": "allow",
          "Get-Content *": "allow",
          "*": "deny"
        },
        "task": "deny"
      }
    }
  }
}
